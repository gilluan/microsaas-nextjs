{
  "name": "microsaas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true npm run build && npx serve analyze/client.html",
    "lighthouse": "npx lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html",
    "perf:audit": "npm run build && npm run lighthouse",
    "amplify:dev": "npx ampx sandbox",
    "amplify:build": "npx ampx generate",
    "amplify:deploy": "npx ampx pipeline-deploy --branch main"
  },
  "dependencies": {
